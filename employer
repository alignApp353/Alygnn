<nav>
  <a class="logo" href="index.html">Alygnn<span>.</span></a>
  <ul class="nav-links">
    <li><a href="#how">How it works</a></li>
    <li><a href="#features">Features</a></li>
    <li><a href="#pricing">Pricing</a></li>
    <li><a href="#post">Post a job</a></li>
  </ul>
  <div style="display:flex;align-items:center;gap:12px;">
    <span class="nav-pill">For Employers</span>
    <button class="nav-cta" onclick="document.getElementById('post').scrollIntoView({behavior:'smooth'})">Post a job</button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
