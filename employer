    <div class="hero-actions">
      <button class="btn-primary" onclick="document.getElementById('post').scrollIntoView({behavior:'smooth'})">Post your first role</button>
      <button class="btn-ghost" onclick="document.getElementById('how').scrollIntoView({behavior:'smooth'})">See how it works</button>
    </div>
  </div>

  <div class="hero-visual">
    <div class="dashboard-mock">
      <div class="dash-header">
        <div>
