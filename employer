<!-- POST A JOB -->
<section class="post-section" id="post">
  <p class="section-label">Post a job</p>
  <h2>Get matched candidates<br>in under 24 hours</h2>
  <div class="post-grid">
    <div>
      <div class="form-group">
        <label>Job title</label>
        <input type="text" placeholder="e.g. Senior Product Designer">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Salary min</label>
          <input type="text" placeholder="$120,000">
        </div>
        <div class="form-group">
          <label>Salary max</label>
          <input type="text" placeholder="$160,000">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Location</label>
          <input type="text" placeholder="San Francisco, CA">
        </div>
        <div class="form-group">
          <label>Work type</label>
          <select>
            <option>Remote</option>
            <option>Hybrid</option>
            <option>On-site</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>401(k) match</label>
        <select>
          <option>No 401(k)</option>
          <option>1% match</option>
          <option>2% match</option>
          <option>3% match</option>
          <option>4% match</option>
          <option>5%+ match</option>
        </select>
      </div>
      <div class="form-group">
        <label>Health coverage</label>
        <select>
          <option>Full coverage (company pays 100%)</option>
          <option>Partial coverage</option>
          <option>Employee-paid</option>
          <option>No health benefits</option>
        </select>
      </div>
      <div class="form-group">
        <label>Required skills <span style="color:var(--text-muted);font-weight:300;">(comma separated)</span></label>
        <input type="text" placeholder="e.g. Figma, Design Systems, B2B SaaS">
      </div>
      <div class="form-group">
        <label>Role description</label>
        <textarea placeholder="Describe the role, team, and what success looks like in the first 90 days…"></textarea>
        <p class="form-hint">The more detail you provide, the better your candidate matches will be.</p>
      </div>
      <div class="form-group">
        <label>Company email</label>
        <input type="email" placeholder="hiring@yourcompany.com">
      </div>
      <button class="form-submit">Post role and find candidates →</button>
    </div>
    <div class="post-aside">
      <div class="aside-card">
        <div class="aside-icon">⚡</div>
        <div class="aside-title">Matches appear within 24 hours</div>
        <p class="aside-desc">Once your role is live, our AI scans the candidate pool and populates your dashboard with pre-screened matches — usually within a few hours.</p>
      </div>
      <div class="aside-card">
        <div class="aside-icon">🔒</div>
        <div class="aside-title">Candidate contact info is gated</div>
        <p class="aside-desc">Candidates control when their contact details are shared. You only receive their info after they swipe right on your role.</p>
      </div>
      <div class="aside-card">
        <div class="aside-icon">💡</div>
        <div class="aside-title">Benefits details matter</div>
        <p class="aside-desc">Job seekers on Alygnn filter hard on 401(k), health, and PTO. Listing your full benefits package increases match volume by up to 60%.</p>
      </div>
      <div class="aside-card" style="background:rgba(93,127,163,0.07);border-color:rgba(93,127,163,0.2);">
        <div class="aside-icon">💬</div>
        <div class="aside-title">Questions? Talk to us.</div>
        <p class="aside-desc">Email <a href="mailto:employers@alygnn.com" style="color:var(--brand);text-decoration:none;">employers@alygnn.com</a> — a real person responds within one business day.</p>
      </div>
    </div>
  </div>
</section>

