            <span class="posting-bar-label">62% reviewed</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="section" style="padding-top:80px;padding-bottom:80px;background:white;">
  <div class="stats-row">
    <div class="stat">
      <div class="stat-num">3.2×</div>
      <div class="stat-label">Faster time-to-hire</div>
    </div>
    <div class="stat">
      <div class="stat-num">91%</div>
      <div class="stat-label">Candidate-to-interview rate</div>
    </div>
    <div class="stat">
      <div class="stat-num">2.4M+</div>
      <div class="stat-label">Active job seekers indexed</div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section" id="how">
  <p class="section-label">How it works</p>
  <h2>Three steps to a<br>full pipeline</h2>
  <p class="section-sub">No resume pile. No cold applications. Just matched candidates who already want what you're offering.</p>
  <div class="steps">
    <div class="step-card" data-num="1">
      <div class="step-icon icon-blue">📋</div>
      <div class="step-title">Post your role</div>
      <p class="step-desc">Fill in your job details — title, salary range, location, benefits, and must-have skills. Takes about 5 minutes.</p>
    </div>
    <div class="step-card" data-num="2">
      <div class="step-icon icon-green">🎯</div>
      <div class="step-title">AI finds your matches</div>
      <p class="step-desc">Our AI scans thousands of job seeker profiles and surfaces candidates whose resumes, salary expectations, and preferences align with your role.</p>
    </div>
    <div class="step-card" data-num="3">
      <div class="step-icon icon-mint">📬</div>
      <div class="step-title">Review and reach out</div>
      <p class="step-desc">Browse matched candidates in your dashboard. See their full profile, match score, and salary ask before making contact.</p>
    </div>
  </div>
</section>

